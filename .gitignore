# ============================================================================
# STG-Mol — .gitignore
# ============================================================================

# ---- Structure / molecular files (typically large) ----
*.pdb
*.pdbqt
*.mol2
*.cif
*.sdf
*.xyz
*.gro
*.tpr
*.trr
*.xtc
*.edr
*.log
*.dcd

# ---- Compressed archives ----
*.zip
*.tar
*.tar.gz
*.tar.xz
*.tgz
*.gz
*.bz2

# ---- Model checkpoints & feature caches ----
*.pt
*.pth
*.ckpt
*.h5
*.pkl
*.pickle
*.npy
*.npz
*.parquet
mol2vec_model.model

# ---- Result / experiment directories ----
results/
screening_results/
validation_results/
experiments/
runs/
outputs/
logs/
cache/
tmp/

# ---- Data directory ----
# Small curated CSVs (train/val/test) ARE tracked so the paper is reproducible.
# Only large files (ZINC library, pretrained Mol2Vec model, feature caches) are ignored.
data/screening_libraries/
data/decoy_generation/
data/external/
data/candidates/md_trajectories/
data/**/mol2vec_model.pkl
data/**/*.parquet
data/**/*.npy
data/**/*.npz
data/**/features/

# ---- Python bytecode & virtual environments ----
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
env/
.eggs/
build/
dist/

# ---- Jupyter ----
.ipynb_checkpoints/
*.ipynb_meta

# ---- IDE / editor ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- System files ----
.DS_Store
Thumbs.db
desktop.ini
